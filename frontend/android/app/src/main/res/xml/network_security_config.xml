<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!--
        Allow HTTP for self-hosted backends on localhost and private LAN IPs.
        CIDR notation is invalid in <domain> elements so base-config is used instead.
        HTTPS remote backends (Render, etc.) are unaffected.
    -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
